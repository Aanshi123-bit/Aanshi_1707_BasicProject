<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sorting Ceremony | Hogwarts Academy</title>

    <link rel="stylesheet" href="/css/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">

</head>

<body>

    <div class="sorting-container">

        <h1>🎩 The Sorting Hat</h1>

        <p>

            "Answer truthfully. The Sorting Hat never makes a mistake."

        </p>

        <form action="/sorting" method="POST">

            <!-- Question 1 -->

            <div class="question">

                <h3>1. Which quality do you value the most?</h3>

                <label><input type="radio" name="q1" value="Gryffindor" required> Courage</label><br>

                <label><input type="radio" name="q1" value="Ravenclaw"> Wisdom</label><br>

                <label><input type="radio" name="q1" value="Hufflepuff"> Loyalty</label><br>

                <label><input type="radio" name="q1" value="Slytherin"> Ambition</label>

            </div>

            <!-- Question 2 -->

            <div class="question">

                <h3>2. Which class would you enjoy the most?</h3>

                <label><input type="radio" name="q2" value="Gryffindor" required> Defence Against the Dark Arts</label><br>

                <label><input type="radio" name="q2" value="Ravenclaw"> Ancient Runes</label><br>

                <label><input type="radio" name="q2" value="Hufflepuff"> Herbology</label><br>

                <label><input type="radio" name="q2" value="Slytherin"> Potions</label>

            </div>

            <!-- Question 3 -->

            <div class="question">

                <h3>3. Your friend is in trouble. You...</h3>

                <label><input type="radio" name="q3" value="Gryffindor" required> Rush to help immediately</label><br>

                <label><input type="radio" name="q3" value="Ravenclaw"> Make the smartest plan</label><br>

                <label><input type="radio" name="q3" value="Hufflepuff"> Stay beside them no matter what</label><br>

                <label><input type="radio" name="q3" value="Slytherin"> Find the quickest winning strategy</label>

            </div>

            <!-- Question 4 -->

            <div class="question">

                <h3>4. Choose a magical creature.</h3>

                <label><input type="radio" name="q4" value="Gryffindor" required> Phoenix</label><br>

                <label><input type="radio" name="q4" value="Ravenclaw"> Owl</label><br>

                <label><input type="radio" name="q4" value="Hufflepuff"> Niffler</label><br>

                <label><input type="radio" name="q4" value="Slytherin"> Basilisk</label>

            </div>

            <!-- Question 5 -->

            <div class="question">

                <h3>5. What motivates you the most?</h3>

                <label><input type="radio" name="q5" value="Gryffindor" required> Bravery</label><br>

                <label><input type="radio" name="q5" value="Ravenclaw"> Knowledge</label><br>

                <label><input type="radio" name="q5" value="Hufflepuff"> Friendship</label><br>

                <label><input type="radio" name="q5" value="Slytherin"> Success</label>

            </div>

            <button type="submit" class="planner-btn">

                Reveal My House

            </button>

        </form>

    </div>

</body>

</html>