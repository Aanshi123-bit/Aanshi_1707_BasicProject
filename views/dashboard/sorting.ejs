<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sorting Ceremony | Hogwarts Academy</title>

    <link rel="stylesheet" href="/css/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

</head>

<body>

    <section class="sorting-page">

        <div class="sorting-box">

            <h1>🎩 The Sorting Ceremony</h1>

            <p>

                Welcome <strong><%= user.name %></strong>.

            </p>

            <p>

                The Great Hall has fallen silent.

                The Sorting Hat is ready to decide your destiny.

            </p>

            <div class="hat">

                🎩

            </div>

            <form action="/sorting" method="POST">

                <button id="sortButton">

                    Begin Sorting Ceremony

                </button>

            </form>

        </div>

    </section>

</body>

</html>