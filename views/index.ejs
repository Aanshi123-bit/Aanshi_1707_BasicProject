<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Hogwarts Academy</title>

    <link rel="stylesheet" href="/css/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

</head>

<body>

    <!-- =================NAVBAR ================= -->

    <nav>

        <div class="logo">

            Hogwarts Academy

        </div>

        <ul>

            <li><a href="/">Home</a></li>

            <li><a href="#features">Features</a></li>

            <li><a href="#houses">Houses</a></li>

            <li><a href="/login">Login</a></li>

        </ul>

        <a href="/signup" class="join">

            Join Hogwarts

        </a>

    </nav>



    <!-- ================= HERO ================= -->

    <section class="hero">

        <div class="hero-text">

            <h1>

                Begin Your Magical Study Journey

            </h1>

            <p>

                Transform your studies into an unforgettable Hogwarts adventure.
                Complete daily goals, earn House Points, unlock magical abilities,
                build study streaks and compete for the legendary House Cup.

            </p>

            <a href="/signup" class="cta">

                Receive Acceptance Letter

            </a>

        </div>

    </section>



    <!-- ================= FEATURES ================= -->

    <section class="features" id="features">

        <h2>

            Magical Features

        </h2>

        <div class="feature-container">

            <div class="card">

                <h3>🏆 House Points</h3>

                <p>

                    Finish your study tasks and earn valuable points for your House.

                </p>

            </div>

            <div class="card">

                <h3>📚 Study Planner</h3>

                <p>

                    Organize subjects, assignments and upcoming exams with ease.

                </p>

            </div>

            <div class="card">

                <h3>🦉 Owl Reminders</h3>

                <p>

                    Receive magical reminders before every important deadline.

                </p>

            </div>

            <div class="card">

                <h3>✨ Unlock Charms</h3>

                <p>

                    Reach 100 personal points to unlock magical rewards and spells.

                </p>

            </div>

            <div class="card">

                <h3>📈 Progress Tracker</h3>

                <p>

                    Track your XP, level, streaks and overall academic journey.

                </p>

            </div>

            <div class="card">

                <h3>🏰 House Cup</h3>

                <p>

                    Help your House become the champion of Hogwarts Academy.

                </p>

            </div>

        </div>

    </section>



    <!-- ================= HOUSES ================= -->

    <section class="houses" id="houses">

        <h2>

            Choose Your Destiny

        </h2>

        <div class="house-container">

            <div class="house">

                <h3>

                    🦁 Gryffindor

                </h3>

                <p>

                    Courage • Determination • Bravery

                </p>

            </div>

            <div class="house">

                <h3>

                    🦅 Ravenclaw

                </h3>

                <p>

                    Wisdom • Intelligence • Creativity

                </p>

            </div>

            <div class="house">

                <h3>

                    🦡 Hufflepuff

                </h3>

                <p>

                    Loyalty • Patience • Hard Work

                </p>

            </div>

            <div class="house">

                <h3>

                    🐍 Slytherin

                </h3>

                <p>

                    Ambition • Leadership • Resourcefulness

                </p>

            </div>

        </div>

    </section>



    <!-- ================= CTA ================= -->

    <section class="start">

        <h2>

            Your Hogwarts Journey Awaits

        </h2>

        <p>

            Every assignment completed brings honor to your House.
            Every streak unlocks greater magical abilities.

        </p>

        <a href="/signup" class="cta">

            Start Your Journey

        </a>

    </section>



    <!-- ================= FOOTER ================= -->

    <footer>

        <h2>

            Hogwarts Academy

        </h2>

        <p>

            A magical study planner inspired by the wizarding world.

        </p>

        <p>

            Made with ⚡ using HTML, CSS, JavaScript, Node.js, Express.js, EJS and MongoDB.

        </p>

    </footer>

</body>

</html>
